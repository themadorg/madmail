{
    "branches": [
        "main"
    ],
    "tagFormat": "v${version}",
    "plugins": [
        "@semantic-release/commit-analyzer",
        "@semantic-release/release-notes-generator",
        [
            "@semantic-release/changelog",
            {
                "changelogFile": "CHANGELOG.md"
            }
        ],
        [
            "@semantic-release/exec",
            {
                "prepareCmd": "echo ${nextRelease.version} > .version && npm version ${nextRelease.version} --no-git-tag-version && sed -i '0,/^version = \"/s/^version = \"[^\"]*\"/version = \"'\"${nextRelease.version}\"'\"/' Cargo.toml && sed -i '/^name = \"\\(chatmail\\|madmail\\)/{n;s/^version = .*/version = \"'\"${nextRelease.version}\"'\"/}' Cargo.lock"
            }
        ],
        [
            "@semantic-release/git",
            {
                "assets": [
                    "package.json",
                    "package-lock.json",
                    "CHANGELOG.md",
                    ".version",
                    "Cargo.toml",
                    "Cargo.lock"
                ],
                "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
            }
        ]
    ]
}
